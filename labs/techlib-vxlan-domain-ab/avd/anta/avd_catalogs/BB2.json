  "anta.tests.connectivity": [
    {
      "VerifyLLDPNeighbors": {
        "result_overwrite": {
          "custom_field": "Generated by AVD"
        },
        "filters": {
          "tags": [
            "BB2"
          ]
        },
        "neighbors": [
          {
            "port": "Ethernet1",
            "neighbor_device": "A-LEAF7",
            "neighbor_port": "Ethernet8"
          },
          {
            "port": "Ethernet2",
            "neighbor_device": "A-LEAF8",
            "neighbor_port": "Ethernet8"
          },
          {
            "port": "Ethernet3",
            "neighbor_device": "B-LEAF7",
            "neighbor_port": "Ethernet8"
          },
          {
            "port": "Ethernet4",
            "neighbor_device": "B-LEAF8",
            "neighbor_port": "Ethernet8"
          },
          {
            "port": "Ethernet5",
            "neighbor_device": "BB1",
            "neighbor_port": "Ethernet5"
          }
        ],
        "require_fqdn": false
      }
    },
    {
      "VerifyReachability": {
        "result_overwrite": {
          "description": "Verifies point-to-point reachability between Ethernet interfaces.",
          "custom_field": "Generated by AVD"
        },
        "filters": {
          "tags": [
            "BB2"
          ]
        },
        "hosts": [
          {
            "destination": "172.16.1.5",
            "source": "172.16.1.4",
            "description": "A-LEAF7_Ethernet8",
            "vrf": "default",
            "repeat": 1
          },
          {
            "destination": "172.16.1.7",
            "source": "172.16.1.6",
            "description": "A-LEAF8_Ethernet8",
            "vrf": "default",
            "repeat": 1
          },
          {
            "destination": "172.16.2.5",
            "source": "172.16.2.4",
            "description": "B-LEAF7_Ethernet8",
            "vrf": "default",
            "repeat": 1
          },
          {
            "destination": "172.16.2.7",
            "source": "172.16.2.6",
            "description": "B-LEAF8_Ethernet8",
            "vrf": "default",
            "repeat": 1
          },
          {
            "destination": "172.16.255.0",
            "source": "172.16.255.1",
            "description": "BB1_Ethernet5",
            "vrf": "default",
            "repeat": 1
          }
        ]
      }
    }
  ],
